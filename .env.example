# Shopify Storefront API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_REVALIDATION_SECRET=set-me-to-a-long-random-string

# Shopify Customer Account API (passwordless customer accounts)
SHOPIFY_SHOP_ID=
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
# SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=  (only for a confidential client)

# Bank details shown on /order-confirmation/[orderId] (50/50 deposit flow)
BANK_NAME=Habib Bank Limited (HBL)
BANK_ACCOUNT_TITLE=Bayan Ethnic Wear (Pvt) Ltd
BANK_ACCOUNT_NUMBER=1234-5678-9012-3456
BANK_IBAN=PK00 HABB 0000 0000 0000 0000

# Site
NEXT_PUBLIC_SITE_URL=https://sanaswebsite.vercel.app

# NOTE: WhatsApp number, Instagram handle and contact email are NOT env vars —
# they live in src/lib/brand.ts as the single source of truth.
